{
  "name": "nebuchadnezzar",
  "version": "0.1.0",
  "private": true,
  "description": "A mobile-first web UI for Claude Code built with Next.js 15, Convex, and the Claude Agent SDK",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/kurisu-agent/Nebuchadnezzar.git"
  },
  "homepage": "https://github.com/kurisu-agent/Nebuchadnezzar",
  "keywords": ["claude", "claude-code", "ai", "agent-sdk", "nextjs", "convex"],
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:convex": "CONVEX_AGENT_MODE=anonymous convex dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write '**/*.{ts,tsx,json,css}'",
    "format:check": "prettier --check '**/*.{ts,tsx,json,css}'",
    "typecheck": "tsc --noEmit",
    "test:e2e": "tsx test-e2e.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.56",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/typography": "^0.5.19",
    "@uiw/react-codemirror": "^4.25.5",
    "convex": "^1.21.0",
    "daisyui": "^5.5.19",
    "material-file-icons": "^2.4.0",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-zoom-pan-pinch": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0"
  }
}
